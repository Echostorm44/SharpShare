<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SharpShare.Views.JoinDialog"
        x:CompileBindings="True"
        Title="Join Session"
        Width="400" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BackgroundPrimaryBrush}">

    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Styles>

    <StackPanel Margin="24" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
            <Path Classes="lucide" Data="{StaticResource LogInIcon}" Width="20" Height="20"
                  Stroke="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Join a SharpShare Session" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Address (IP:Port)" FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="AddressInput" Watermark="192.168.1.10:9500"
                     FontSize="14" />
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Passphrase" FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <TextBox x:Name="PassphraseInput" Watermark="tiger-ocean-seven"
                     FontSize="14" FontFamily="Consolas,monospace" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12"
                    Margin="0,8,0,0">
            <Button x:Name="CancelButton" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="lucide" Data="{StaticResource XIcon}" Width="13" Height="13"
                          Stroke="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button x:Name="ConnectButton" Classes="accent" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="lucide" Data="{StaticResource LinkIcon}" Width="13" Height="13"
                          Stroke="White" />
                    <TextBlock Text="Connect" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
