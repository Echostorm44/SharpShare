<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SharpShare.Views.SettingsWindow"
        x:CompileBindings="True"
        Title="Settings"
        Width="450" Height="400"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BackgroundPrimaryBrush}">

    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </Window.Styles>

    <StackPanel Margin="24" Spacing="20">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Path Classes="lucide" Data="{StaticResource SettingsIcon}" Width="20" Height="20"
                  Stroke="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </StackPanel>

        <!-- Port -->
        <StackPanel Spacing="4">
            <TextBlock Text="Listening Port" FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
            <NumericUpDown x:Name="PortInput" Minimum="1024" Maximum="65535"
                           Value="9500" FormatString="0" />
            <TextBlock Text="Changes take effect on next host session"
                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- UPnP toggle -->
        <StackPanel Spacing="4">
            <CheckBox x:Name="UpnpToggle" Content="Enable UPnP (automatic port forwarding)"
                      FontSize="13" />
        </StackPanel>

        <!-- Max speed -->
        <StackPanel Spacing="4">
            <TextBlock Text="Max Transfer Speed (MB/s, 0 = unlimited)" FontSize="13"
                       FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" />
            <NumericUpDown x:Name="MaxSpeedInput" Minimum="0" Maximum="10000"
                           Value="0" FormatString="0" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12"
                    Margin="0,12,0,0">
            <Button x:Name="CancelButton" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="lucide" Data="{StaticResource XIcon}" Width="13" Height="13"
                          Stroke="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
            <Button x:Name="SaveButton" Classes="accent" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Path Classes="lucide" Data="{StaticResource CheckCircleIcon}" Width="13" Height="13"
                          Stroke="White" />
                    <TextBlock Text="Save" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
